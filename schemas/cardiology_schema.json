{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WITNESS DATA FACTORY — Cardiology Record Schema",
  "description": "Schema for synthetic cardiology clinical records. Trinity QA gate >= 0.97.",
  "type": "object",
  "required": ["id", "domain", "text", "labels", "eval"],
  "properties": {
    "id": { "type": "string", "pattern": "^CAR-[0-9]{6}$" },
    "domain": { "type": "string", "const": "cardiology" },
    "text": { "type": "string", "minLength": 50 },
    "labels": {
      "type": "object",
      "properties": {
        "primary_diagnosis": { "type": "string" },
        "icd10": { "type": "string" },
        "severity": { "type": "string", "enum": ["Mild", "Moderate", "Severe", "Critical"] }
      }
    },
    "eval": {
      "type": "object",
      "required": ["confidence"],
      "properties": {
        "confidence": { "type": "number", "minimum": 0.97, "maximum": 1.0 }
      }
    }
  }
}
