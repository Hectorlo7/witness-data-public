{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WITNESS DATA FACTORY — Neurology Record Schema",
  "type": "object",
  "required": ["id", "domain", "text", "labels", "eval"],
  "properties": {
    "id": { "type": "string", "pattern": "^NEU-[0-9]{6}$" },
    "domain": { "type": "string", "const": "neurology" },
    "text": { "type": "string", "minLength": 50 },
    "labels": {
      "type": "object",
      "properties": {
        "primary_diagnosis": { "type": "string" },
        "icd10": { "type": "string" },
        "severity": { "type": "string", "enum": ["Mild", "Moderate", "Severe", "Critical"] }
      }
    },
    "eval": {
      "type": "object",
      "required": ["confidence"],
      "properties": { "confidence": { "type": "number", "minimum": 0.97 } }
    }
  }
}
