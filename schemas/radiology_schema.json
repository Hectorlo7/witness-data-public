{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WITNESS DATA FACTORY — Radiology Record Schema",
  "type": "object",
  "required": ["id", "domain", "text", "labels", "eval"],
  "properties": {
    "id": { "type": "string", "pattern": "^RAD-[0-9]{6}$" },
    "domain": { "type": "string", "const": "radiology" },
    "text": { "type": "string", "minLength": 50 },
    "labels": {
      "type": "object",
      "properties": {
        "primary_finding": { "type": "string" },
        "modality": { "type": "string", "enum": ["CT", "MRI", "XR", "US", "PET-CT", "Mammography", "Echo", "Fluoroscopy"] },
        "impression": { "type": "string" }
      }
    },
    "eval": {
      "type": "object",
      "required": ["confidence"],
      "properties": { "confidence": { "type": "number", "minimum": 0.97 } }
    }
  }
}
