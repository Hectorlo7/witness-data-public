{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WITNESS DATA FACTORY — Surgical Record Schema",
  "type": "object",
  "required": ["id", "domain", "text", "labels", "eval"],
  "properties": {
    "id": { "type": "string", "pattern": "^SURG-[0-9]{6}$" },
    "domain": { "type": "string", "const": "surgical" },
    "text": { "type": "string", "minLength": 50 },
    "labels": {
      "type": "object",
      "properties": {
        "primary_procedure": { "type": "string" },
        "icd10": { "type": "string" },
        "phase": { "type": "string", "enum": ["Pre-Operative", "Intra-Operative", "Post-Operative"] }
      }
    },
    "eval": {
      "type": "object",
      "required": ["confidence"],
      "properties": { "confidence": { "type": "number", "minimum": 0.97 } }
    }
  }
}
